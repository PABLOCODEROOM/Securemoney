# ─────────────────────────────────────────────
#  SecureMoney — Environment Configuration
#  Copy this to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Flask core
FLASK_ENV=development
FLASK_DEBUG=0
SECRET_KEY=change-this-to-a-long-random-secret-key-at-least-32-chars

# Database (MySQL 8.0 via XAMPP)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=securemoney
DB_USER=root
DB_PASSWORD=

# AES-256-GCM Master Key Material
# 32-byte hex string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
MASTER_KEY_HEX=replace_with_64_hex_chars_generated_by_python_secrets

# PBKDF2 parameters
PBKDF2_ITERATIONS=600000
PBKDF2_HASH=SHA-256

# OTP settings
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6

# Session
SESSION_TIMEOUT_MINUTES=15

# Email simulation (set SIMULATE=true to print OTP to console instead of sending)
EMAIL_SIMULATE=true
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=noreply@securemoney.local
EMAIL_PASSWORD=

# Admin bootstrap credentials (change immediately after first login)
ADMIN_BOOTSTRAP_PASSWORD=Admin@SecureMoney2026!
